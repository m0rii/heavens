{
  "name": "heavens-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.16.0 <25",
    "npm": ">=11.13.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test tests/e2e/a11y.spec.ts",
    "validate:content": "node scripts/validate-content.mjs",
    "validate:routes": "node scripts/validate-routes.mjs",
    "validate:seo": "node scripts/validate-seo.mjs",
    "validate:production": "node scripts/validate-production-config.mjs",
    "check:budgets": "node scripts/check-budgets.mjs",
    "ci": "npm run format:check && npm run lint && npm run check && npm run test && npm run build && npm run validate:content && npm run validate:routes && npm run validate:seo && npm run validate:production && npm run check:budgets"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.6",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "eslint": "^10.4.1",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "7.3.5",
    "vitest": "^4.0.15"
  },
  "overrides": {
    "vite": "7.3.5",
    "yaml": "2.9.0"
  }
}
