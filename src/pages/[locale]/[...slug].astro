---
import { contactFormName, enquiryTypes } from '@/lib/forms';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { brandAssets } from '@/config/brand';
import { socialProfiles } from '@/config/social';
import InstagramIcon from '@/components/InstagramIcon.astro';
import {
  getRouteMatrix,
  isAnyRouteSlug,
  localizedPath,
  type AnyRouteSlug,
} from '@/config/routes';
import { isLocale, type Locale } from '@/i18n/config';
import { getDictionary } from '@/i18n/ui';

export function getStaticPaths() {
  return getRouteMatrix(true).map(({ locale, slug }) => ({
    params: { locale, slug: slug || undefined },
    props: { locale, slug },
  }));
}

const localeParam = Astro.params.locale;
const slugParam = Array.isArray(Astro.params.slug)
  ? Astro.params.slug.join('/')
  : (Astro.params.slug ?? '');

if (!isLocale(localeParam) || !isAnyRouteSlug(slugParam)) {
  return Astro.redirect('/404/');
}

const locale = Astro.props.locale as Locale;
const slug = Astro.props.slug as AnyRouteSlug;
const dictionary = getDictionary(locale);
const page = dictionary.pages[slug];
const isHome = slug === '';
const formCopy = dictionary.form;
---

<BaseLayout locale={locale} slug={slug}>
  <section class:list={['hero', isHome && 'hero-home']}>
    <div class="container hero-inner">
      <div class="hero-copy">
        {page.eyebrow && <p class="eyebrow">{page.eyebrow}</p>}
        {
          isHome ? (
            <h1 class="hero-title">
              <span>Live the</span>
              <span>Dream.</span>
            </h1>
          ) : (
            <h1>{page.heading}</h1>
          )
        }
        <p class="lead">{page.intro}</p>
        {
          isHome && (
            <p class="hero-actions">
              <a
                class="button button-primary-dark"
                href={localizedPath(locale, 'about')}
              >
                {dictionary.actions.discover}
              </a>
              <a
                class="button button-secondary-dark"
                href={localizedPath(locale, 'contact')}
              >
                {dictionary.actions.contact}
              </a>
            </p>
          )
        }
      </div>
      {
        isHome && (
          <img
            class="hero-graphic"
            src={brandAssets.heroGraphic.src}
            width={brandAssets.heroGraphic.width}
            height={brandAssets.heroGraphic.height}
            alt=""
            aria-hidden="true"
          />
        )
      }
    </div>
  </section>

  <section class="section section-ivory">
    <div class="container">
      <div class="grid">
        {
          page.sections.map((section) => (
            <article class="card">
              <h2>{section.title}</h2>
              <p>{section.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  {
    slug === 'contact' && (
      <section class="section section-ivory">
        <div class="container contact-shell">
          <div class="contact-form-panel">
            <div class="form-heading">
              <h2>{formCopy.heading}</h2>
              <p>{formCopy.intro}</p>
              <p class="required-note">{formCopy.requiredNote}</p>
            </div>
            <form
              name={contactFormName}
              method="POST"
              action={localizedPath(locale, 'contact/success')}
              data-netlify="true"
              data-netlify-honeypot="bot-field"
              data-enhanced-contact-form
              data-success-url={localizedPath(locale, 'contact/success')}
              data-status-idle={formCopy.status.idle}
              data-status-pending={formCopy.status.pending}
              data-status-success={formCopy.status.success}
              data-status-failure={formCopy.status.failure}
              data-error-summary={formCopy.errors.summary}
              data-error-required-text={formCopy.errors.requiredText}
              data-error-email={formCopy.errors.email}
              data-error-enquiry-type={formCopy.errors.enquiryType}
              data-error-message={formCopy.errors.message}
              data-error-privacy={formCopy.errors.privacy}
              data-error-max-length={formCopy.errors.maxLength}
              class="contact-form"
            >
              <input type="hidden" name="form-name" value={contactFormName} />
              <input type="hidden" name="locale" value={locale} />
              <p class="honeypot" aria-hidden="true">
                <label>
                  {formCopy.labels.honeypot}
                  <input name="bot-field" tabindex="-1" autocomplete="off" />
                </label>
              </p>
              <div
                id="form-status"
                class="form-status"
                role="status"
                aria-live="polite"
                aria-atomic="true"
                tabindex="-1"
              />
              <div
                id="form-error-summary"
                class="form-error-summary"
                tabindex="-1"
                hidden
              />
              <div class="form-grid">
                <div class="field">
                  <label for="full-name">
                    <span>
                      {formCopy.labels.fullName}
                      <span aria-hidden="true">*</span>
                    </span>
                  </label>
                  <input
                    id="full-name"
                    name="full-name"
                    type="text"
                    autocomplete="name"
                    minlength="2"
                    maxlength="100"
                    required
                    aria-describedby="full-name-error"
                  />
                  <p
                    id="full-name-error"
                    class="field-error"
                    data-field-error="full-name"
                  />
                </div>
                <div class="field">
                  <label for="company">
                    <span>
                      {formCopy.labels.company}
                      <span class="optional">{formCopy.optional}</span>
                    </span>
                  </label>
                  <input
                    id="company"
                    name="company"
                    type="text"
                    autocomplete="organization"
                    maxlength="150"
                    aria-describedby="company-error"
                  />
                  <p
                    id="company-error"
                    class="field-error"
                    data-field-error="company"
                  />
                </div>
                <div class="field">
                  <label for="email">
                    <span>
                      {formCopy.labels.email}
                      <span aria-hidden="true">*</span>
                    </span>
                  </label>
                  <input
                    id="email"
                    name="email"
                    type="email"
                    autocomplete="email"
                    inputmode="email"
                    maxlength="254"
                    required
                    aria-describedby="email-error"
                  />
                  <p
                    id="email-error"
                    class="field-error"
                    data-field-error="email"
                  />
                </div>
                <div class="field">
                  <label for="phone">
                    <span>
                      {formCopy.labels.phone}
                      <span class="optional">{formCopy.optional}</span>
                    </span>
                  </label>
                  <input
                    id="phone"
                    name="phone"
                    type="tel"
                    autocomplete="tel"
                    inputmode="tel"
                    maxlength="40"
                    aria-describedby="phone-error"
                  />
                  <p
                    id="phone-error"
                    class="field-error"
                    data-field-error="phone"
                  />
                </div>
                <div class="field">
                  <label for="country">
                    <span>
                      {formCopy.labels.country}
                      <span class="optional">{formCopy.optional}</span>
                    </span>
                  </label>
                  <input
                    id="country"
                    name="country"
                    type="text"
                    autocomplete="country-name"
                    maxlength="100"
                    aria-describedby="country-error"
                  />
                  <p
                    id="country-error"
                    class="field-error"
                    data-field-error="country"
                  />
                </div>
                <div class="field">
                  <label for="enquiry-type">
                    <span>
                      {formCopy.labels.enquiryType}
                      <span aria-hidden="true">*</span>
                    </span>
                  </label>
                  <select
                    id="enquiry-type"
                    name="enquiry-type"
                    required
                    aria-describedby="enquiry-type-error"
                  >
                    <option value="" selected disabled>
                      {formCopy.selectEnquiryType}
                    </option>
                    {enquiryTypes.map((type) => (
                      <option value={type}>
                        {formCopy.enquiryTypes[type]}
                      </option>
                    ))}
                  </select>
                  <p
                    id="enquiry-type-error"
                    class="field-error"
                    data-field-error="enquiry-type"
                  />
                </div>
                <div class="field field-full">
                  <label for="message">
                    <span>
                      {formCopy.labels.message}
                      <span aria-hidden="true">*</span>
                    </span>
                  </label>
                  <textarea
                    id="message"
                    name="message"
                    minlength="10"
                    maxlength="5000"
                    rows="8"
                    required
                    aria-describedby="message-count message-error"
                  />
                  <div class="field-meta">
                    <p
                      id="message-error"
                      class="field-error"
                      data-field-error="message"
                    />
                    <p
                      id="message-count"
                      class="character-count"
                      aria-live="polite"
                    >
                      0 / 5000
                    </p>
                  </div>
                </div>
                <div class="checkbox-field field-full">
                  <input
                    id="privacy-acknowledgement"
                    name="privacy-acknowledgement"
                    type="checkbox"
                    value="acknowledged"
                    required
                    aria-describedby="privacy-acknowledgement-error"
                  />
                  <label for="privacy-acknowledgement">
                    <span>
                      {formCopy.labels.privacyAcknowledgement}{' '}
                      <a href={localizedPath(locale, 'privacy')}>
                        {formCopy.labels.privacyPolicy}
                      </a>
                      <span aria-hidden="true">*</span>
                    </span>
                  </label>
                  <p
                    id="privacy-acknowledgement-error"
                    class="field-error"
                    data-field-error="privacy-acknowledgement"
                  />
                </div>
                <div class="field-full">
                  <button
                    class="button button-primary-light form-submit"
                    type="submit"
                  >
                    {formCopy.status.idle}
                  </button>
                </div>
              </div>
            </form>
          </div>
          <aside class="contact-info" aria-labelledby="contact-info-title">
            <h2 id="contact-info-title">{dictionary.actions.followHeavens}</h2>
            <p>{page.sections[0]?.body}</p>
            <a
              class="social-link contact-social-link"
              href={socialProfiles.instagram.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={socialProfiles.instagram.label}
            >
              <InstagramIcon />
              <span>{dictionary.social.instagram}</span>
            </a>
          </aside>
        </div>
        <script is:inline src="/scripts/contact-form.js" defer />
      </section>
    )
  }
</BaseLayout>
