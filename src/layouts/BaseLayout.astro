---
import {
  getEquivalentPaths,
  localizedPath,
  routeSlugs,
  type AnyRouteSlug,
} from '@/config/routes';
import { brandAssets } from '@/config/brand';
import { company } from '@/config/company';
import { site } from '@/config/site';
import { socialProfiles } from '@/config/social';
import InstagramIcon from '@/components/InstagramIcon.astro';
import {
  getDirection,
  localeCodes,
  localeFlags,
  localeNames,
  locales,
  type Locale,
} from '@/i18n/config';
import { getDictionary } from '@/i18n/ui';
import { canonicalUrl, hreflang, ogLocale } from '@/lib/seo';
import { breadcrumbJsonLd, organizationJsonLd } from '@/lib/structured-data';
import '@/styles/global.css';

interface Props {
  locale: Locale;
  slug: AnyRouteSlug;
}

const { locale, slug } = Astro.props;
const dictionary = getDictionary(locale);
const page = dictionary.pages[slug];
const equivalents = getEquivalentPaths(slug);
const isNoindex = slug === 'contact/success';
const primaryNavItems = [
  ['home', ''],
  ['about', 'about'],
  ['business', 'business'],
  ['technology', 'technology'],
  ['media', 'media'],
  ['contact', 'contact'],
] as const;
const desktopNavItems = primaryNavItems.filter(([key]) => key !== 'home');
const languageMenuId = `language-menu-${locale}-${slug || 'home'}`;
const mobileDrawerId = `mobile-drawer-${locale}-${slug || 'home'}`;
---

<!doctype html>
<html lang={locale} dir={getDirection(locale)}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{page.title}</title>
    <meta name="description" content={page.description} />
    <meta name="theme-color" content="#0A0D09" />
    <meta
      name="robots"
      content={isNoindex ? 'noindex, nofollow' : 'index, follow'}
    />
    <link rel="canonical" href={canonicalUrl(locale, slug)} />
    <link rel="icon" href={brandAssets.icons.faviconIco} sizes="any" />
    <link
      rel="icon"
      type="image/png"
      href={brandAssets.icons.faviconPng}
      sizes="32x32"
    />
    <link rel="apple-touch-icon" href={brandAssets.icons.appleTouchIcon} />
    <link rel="manifest" href="/site.webmanifest" />
    {
      hreflang(locale, slug).map((item) => (
        <link rel="alternate" hreflang={item.lang} href={item.href} />
      ))
    }
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.brandName} />
    <meta property="og:title" content={page.title} />
    <meta property="og:description" content={page.description} />
    <meta property="og:url" content={canonicalUrl(locale, slug)} />
    <meta
      property="og:image"
      content={`${site.origin}${brandAssets.logo.src}`}
    />
    <meta
      name="twitter:image"
      content={`${site.origin}${brandAssets.logo.src}`}
    />
    <meta property="og:locale" content={ogLocale(locale)} />
    {
      locales
        .filter((item) => item !== locale)
        .map((item) => (
          <meta property="og:locale:alternate" content={ogLocale(item)} />
        ))
    }
    <meta name="twitter:card" content="summary_large_image" />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(organizationJsonLd())}
    />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(breadcrumbJsonLd(locale, slug, page.heading))}
    />
  </head>
  <body>
    <a href="#main" class="skip-link">{dictionary.actions.skip}</a>
    <header class="site-header" data-site-header>
      <div class="container header-inner">
        <a
          class="brand"
          href={localizedPath(locale)}
          aria-label={dictionary.actions.heavensHome}
        >
          <img
            src={brandAssets.logo.src}
            width={brandAssets.logo.width}
            height={brandAssets.logo.height}
            alt="Heavens"
          />
          <span class="header-brand-meta">{site.slogan}</span>
        </a>
        <nav
          class="nav desktop-nav"
          aria-label={dictionary.actions.primaryNavigation}
        >
          {
            desktopNavItems.map(([key, itemSlug]) => (
              <a
                href={localizedPath(locale, itemSlug)}
                aria-current={slug === itemSlug ? 'page' : undefined}
              >
                {dictionary.nav[key]}
              </a>
            ))
          }
        </nav>
        <div class="header-actions">
          <details class="language-switcher" data-dropdown>
            <summary
              class="language-trigger"
              role="button"
              aria-label={`${dictionary.actions.currentLanguage}: ${localeNames[locale]}`}
              aria-controls={languageMenuId}
              data-dropdown-trigger
            >
              <span>{localeCodes[locale]}</span>
              <span aria-hidden="true">▾</span>
            </summary>
            <nav
              class="language-menu"
              id={languageMenuId}
              aria-label={dictionary.actions.language}
            >
              {
                locales.map((item) => (
                  <a
                    href={equivalents[item]}
                    hreflang={item}
                    lang={item}
                    aria-current={item === locale ? 'true' : undefined}
                    data-language-link
                  >
                    <span aria-hidden="true">{localeFlags[item]}</span>
                    <span>{localeNames[item]}</span>
                    {item === locale && <span class="active-mark">✓</span>}
                  </a>
                ))
              }
            </nav>
          </details>
          <button
            class="mobile-menu-trigger"
            type="button"
            aria-label={dictionary.actions.openNavigation}
            aria-expanded="false"
            aria-controls={mobileDrawerId}
            data-mobile-menu-trigger
            data-open-label={dictionary.actions.openNavigation}
            data-close-label={dictionary.actions.closeNavigation}
          >
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
          </button>
          <div class="mobile-drawer-overlay" hidden data-mobile-drawer-overlay>
          </div>
          <aside
            class="mobile-drawer"
            id={mobileDrawerId}
            aria-label={dictionary.actions.mobileNavigation}
            aria-hidden="true"
            inert
            data-mobile-drawer
          >
            <div class="mobile-drawer-header">
              <a
                class="brand mobile-drawer-brand"
                href={localizedPath(locale)}
                aria-label={dictionary.actions.heavensHome}
                data-mobile-drawer-link
              >
                <img
                  src={brandAssets.logo.src}
                  width={brandAssets.logo.width}
                  height={brandAssets.logo.height}
                  alt="Heavens"
                />
              </a>
              <button
                class="mobile-drawer-close"
                type="button"
                aria-label={dictionary.actions.closeNavigation}
                data-mobile-drawer-close
              >
                <span aria-hidden="true">×</span>
              </button>
            </div>
            <nav
              class="mobile-drawer-nav"
              aria-label={dictionary.actions.mobileNavigation}
            >
              {
                primaryNavItems.map(([key, itemSlug]) => (
                  <a
                    href={localizedPath(locale, itemSlug)}
                    aria-current={slug === itemSlug ? 'page' : undefined}
                    data-mobile-drawer-link
                  >
                    {dictionary.nav[key]}
                  </a>
                ))
              }
            </nav>
            <div class="mobile-drawer-divider"></div>
            <section
              class="mobile-drawer-languages"
              aria-label={dictionary.actions.language}
            >
              <p class="mobile-drawer-section-label">
                {dictionary.actions.language}
              </p>
              <div class="mobile-language-grid">
                {
                  locales.map((item) => (
                    <a
                      href={equivalents[item]}
                      hreflang={item}
                      lang={item}
                      aria-current={item === locale ? 'true' : undefined}
                      data-language-link
                      data-mobile-drawer-link
                    >
                      <span dir="auto">{localeNames[item]}</span>
                      {item === locale && <span class="active-mark">✓</span>}
                    </a>
                  ))
                }
              </div>
            </section>
            <a
              class="button button-primary-dark mobile-drawer-cta"
              href={localizedPath(locale, 'contact')}
              data-mobile-drawer-link
            >
              {dictionary.actions.contact}
            </a>
            <a
              class="social-link mobile-drawer-social"
              href={socialProfiles.instagram.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={socialProfiles.instagram.label}
              data-mobile-drawer-link
            >
              <InstagramIcon />
              <span>{dictionary.social.instagram}</span>
            </a>
          </aside>
        </div>
      </div>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="site-header">
      <div class="container footer-inner">
        <a
          class="brand footer-brand"
          href={localizedPath(locale)}
          aria-label={dictionary.actions.heavensHome}
        >
          <img
            src={brandAssets.logo.src}
            width={brandAssets.logo.width}
            height={brandAssets.logo.height}
            alt="Heavens"
          />
          <span>
            <span class="footer-brand-meta">{site.slogan}</span>
          </span>
        </a>
        <nav class="nav" aria-label={dictionary.actions.legalNavigation}>
          {
            routeSlugs
              .filter((item) =>
                ['legal', 'privacy', 'cookies', 'terms', 'contact'].includes(
                  item,
                ),
              )
              .map((item) => (
                <a href={localizedPath(locale, item)}>
                  {item === 'contact'
                    ? dictionary.nav.contact
                    : dictionary.pages[item].heading}
                </a>
              ))
          }
        </nav>
        <div class="footer-company-details">
          <p>{company.legalName}</p>
          <p>
            {dictionary.company.address}: {company.address.full}
          </p>
          <p>
            {dictionary.company.registrationNumber}: {
              company.registrationNumber
            }
          </p>
          <p>
            {dictionary.company.taxCode}: {company.taxCode}
          </p>
          <p>
            © {new Date().getFullYear()}
            {company.legalName}. {dictionary.company.rights}
          </p>
        </div>
        <a
          class="social-link footer-social-link"
          href={socialProfiles.instagram.url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={socialProfiles.instagram.label}
        >
          <InstagramIcon />
          <span>{dictionary.social.instagram}</span>
        </a>
        <button class="footer-cookie-settings" type="button" data-consent-open>
          {dictionary.consent.cookieSettings}
        </button>
      </div>
    </footer>
    <div
      class="consent-status"
      role="status"
      aria-live="polite"
      data-consent-status
    >
    </div>
    <section
      class="consent-banner"
      aria-labelledby="consent-banner-title"
      data-consent-banner
      hidden
    >
      <div class="consent-banner-copy">
        <h2 id="consent-banner-title">{dictionary.consent.bannerTitle}</h2>
        <p>{dictionary.consent.bannerBody}</p>
      </div>
      <div class="consent-actions">
        <button
          class="consent-button"
          type="button"
          data-consent-choice="essential"
          data-consent-message={dictionary.consent.savedEssential}
        >
          {dictionary.consent.essentialOnly}
        </button>
        <button
          class="consent-button"
          type="button"
          data-consent-choice="analytics"
          data-consent-message={dictionary.consent.savedAnalytics}
        >
          {dictionary.consent.acceptAnalytics}
        </button>
        <button
          class="consent-button consent-button-subtle"
          type="button"
          data-consent-open
        >
          {dictionary.consent.cookieSettings}
        </button>
      </div>
    </section>
    <div class="consent-backdrop" data-consent-backdrop hidden></div>
    <section
      class="consent-panel"
      aria-labelledby="consent-panel-title"
      data-consent-panel
      hidden
    >
      <div class="consent-panel-header">
        <div>
          <h2 id="consent-panel-title" tabindex="-1">
            {dictionary.consent.panelTitle}
          </h2>
          <p>{dictionary.consent.panelIntro}</p>
        </div>
        <button
          class="consent-close"
          type="button"
          aria-label={dictionary.consent.close}
          data-consent-close
        >
          <span aria-hidden="true">×</span>
        </button>
      </div>
      <div class="consent-option">
        <div>
          <h3>{dictionary.consent.essentialTitle}</h3>
          <p>{dictionary.consent.essentialBody}</p>
        </div>
        <strong>{dictionary.consent.alwaysActive}</strong>
      </div>
      <label class="consent-option consent-option-toggle">
        <span>
          <strong>{dictionary.consent.analyticsTitle}</strong>
          <span>{dictionary.consent.analyticsBody}</span>
          <span>{dictionary.consent.analyticsInactive}</span>
        </span>
        <input type="checkbox" data-consent-analytics />
      </label>
      <div class="consent-panel-actions">
        <button
          class="consent-button"
          type="button"
          data-consent-save
          data-consent-message={dictionary.consent.savedChoices}
        >
          {dictionary.consent.saveChoices}
        </button>
        <button
          class="consent-button"
          type="button"
          data-consent-choice="analytics"
          data-consent-message={dictionary.consent.savedAnalytics}
        >
          {dictionary.consent.acceptAnalytics}
        </button>
        <button
          class="consent-button consent-button-subtle"
          type="button"
          data-consent-choice="essential"
          data-consent-message={dictionary.consent.savedEssential}
        >
          {dictionary.consent.essentialOnly}
        </button>
      </div>
    </section>
    <script is:inline src="/scripts/language-preference.js" defer></script>
    <script is:inline src="/scripts/privacy-consent.js" defer></script>
  </body>
</html>
