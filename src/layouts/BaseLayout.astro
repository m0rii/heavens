---
import {
  getEquivalentPaths,
  localizedPath,
  routeSlugs,
  type AnyRouteSlug,
} from '@/config/routes';
import { brandAssets } from '@/config/brand';
import { site } from '@/config/site';
import { socialProfiles } from '@/config/social';
import InstagramIcon from '@/components/InstagramIcon.astro';
import {
  getDirection,
  localeCodes,
  localeFlags,
  localeNames,
  locales,
  type Locale,
} from '@/i18n/config';
import { getDictionary } from '@/i18n/ui';
import { canonicalUrl, hreflang, ogLocale } from '@/lib/seo';
import { breadcrumbJsonLd, organizationJsonLd } from '@/lib/structured-data';
import '@/styles/global.css';

interface Props {
  locale: Locale;
  slug: AnyRouteSlug;
}

const { locale, slug } = Astro.props;
const dictionary = getDictionary(locale);
const page = dictionary.pages[slug];
const equivalents = getEquivalentPaths(slug);
const isNoindex = slug === 'contact/success';
const primaryNavItems = [
  ['home', ''],
  ['about', 'about'],
  ['business', 'business'],
  ['technology', 'technology'],
  ['media', 'media'],
  ['contact', 'contact'],
] as const;
const desktopNavItems = primaryNavItems.filter(([key]) => key !== 'home');
const languageMenuId = `language-menu-${locale}-${slug || 'home'}`;
const mobileDrawerId = `mobile-drawer-${locale}-${slug || 'home'}`;
---

<!doctype html>
<html lang={locale} dir={getDirection(locale)}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{page.title}</title>
    <meta name="description" content={page.description} />
    <meta name="theme-color" content="#0A0D09" />
    <meta
      name="robots"
      content={isNoindex ? 'noindex, nofollow' : 'index, follow'}
    />
    <link rel="canonical" href={canonicalUrl(locale, slug)} />
    <link rel="icon" href={brandAssets.icons.faviconIco} sizes="any" />
    <link
      rel="icon"
      type="image/png"
      href={brandAssets.icons.faviconPng}
      sizes="32x32"
    />
    <link rel="apple-touch-icon" href={brandAssets.icons.appleTouchIcon} />
    <link rel="manifest" href="/site.webmanifest" />
    {
      hreflang(locale, slug).map((item) => (
        <link rel="alternate" hreflang={item.lang} href={item.href} />
      ))
    }
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.brandName} />
    <meta property="og:title" content={page.title} />
    <meta property="og:description" content={page.description} />
    <meta property="og:url" content={canonicalUrl(locale, slug)} />
    <meta
      property="og:image"
      content={`${site.origin}${brandAssets.logo.src}`}
    />
    <meta
      name="twitter:image"
      content={`${site.origin}${brandAssets.logo.src}`}
    />
    <meta property="og:locale" content={ogLocale(locale)} />
    {
      locales
        .filter((item) => item !== locale)
        .map((item) => (
          <meta property="og:locale:alternate" content={ogLocale(item)} />
        ))
    }
    <meta name="twitter:card" content="summary_large_image" />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(organizationJsonLd())}
    />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(breadcrumbJsonLd(locale, slug, page.heading))}
    />
  </head>
  <body>
    <a href="#main" class="skip-link">{dictionary.actions.skip}</a>
    <header class="site-header" data-site-header>
      <div class="container header-inner">
        <a class="brand" href={localizedPath(locale)} aria-label="Heavens home">
          <img
            src={brandAssets.logo.src}
            width={brandAssets.logo.width}
            height={brandAssets.logo.height}
            alt="Heavens"
          />
          <span class="header-brand-meta">{site.slogan}</span>
        </a>
        <nav class="nav desktop-nav" aria-label="Primary navigation">
          {
            desktopNavItems.map(([key, itemSlug]) => (
              <a
                href={localizedPath(locale, itemSlug)}
                aria-current={slug === itemSlug ? 'page' : undefined}
              >
                {dictionary.nav[key]}
              </a>
            ))
          }
        </nav>
        <div class="header-actions">
          <details class="language-switcher" data-dropdown>
            <summary
              class="language-trigger"
              role="button"
              aria-label={`Current language: ${localeNames[locale]}`}
              aria-controls={languageMenuId}
              data-dropdown-trigger
            >
              <span>{localeCodes[locale]}</span>
              <span aria-hidden="true">▾</span>
            </summary>
            <nav
              class="language-menu"
              id={languageMenuId}
              aria-label="Language"
            >
              {
                locales.map((item) => (
                  <a
                    href={equivalents[item]}
                    hreflang={item}
                    lang={item}
                    aria-current={item === locale ? 'true' : undefined}
                    data-language-link
                  >
                    <span aria-hidden="true">{localeFlags[item]}</span>
                    <span>{localeNames[item]}</span>
                    {item === locale && <span class="active-mark">✓</span>}
                  </a>
                ))
              }
            </nav>
          </details>
          <button
            class="mobile-menu-trigger"
            type="button"
            aria-label="Open navigation"
            aria-expanded="false"
            aria-controls={mobileDrawerId}
            data-mobile-menu-trigger
          >
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
          </button>
          <div class="mobile-drawer-overlay" hidden data-mobile-drawer-overlay>
          </div>
          <aside
            class="mobile-drawer"
            id={mobileDrawerId}
            aria-label="Mobile navigation"
            aria-hidden="true"
            inert
            data-mobile-drawer
          >
            <div class="mobile-drawer-header">
              <a
                class="brand mobile-drawer-brand"
                href={localizedPath(locale)}
                aria-label="Heavens home"
                data-mobile-drawer-link
              >
                <img
                  src={brandAssets.logo.src}
                  width={brandAssets.logo.width}
                  height={brandAssets.logo.height}
                  alt="Heavens"
                />
              </a>
              <button
                class="mobile-drawer-close"
                type="button"
                aria-label="Close navigation"
                data-mobile-drawer-close
              >
                <span aria-hidden="true">×</span>
              </button>
            </div>
            <nav class="mobile-drawer-nav" aria-label="Mobile navigation">
              {
                primaryNavItems.map(([key, itemSlug]) => (
                  <a
                    href={localizedPath(locale, itemSlug)}
                    aria-current={slug === itemSlug ? 'page' : undefined}
                    data-mobile-drawer-link
                  >
                    {dictionary.nav[key]}
                  </a>
                ))
              }
            </nav>
            <div class="mobile-drawer-divider"></div>
            <section class="mobile-drawer-languages" aria-label="Language">
              <p class="mobile-drawer-section-label">Language</p>
              <div class="mobile-language-grid">
                {
                  locales.map((item) => (
                    <a
                      href={equivalents[item]}
                      hreflang={item}
                      lang={item}
                      aria-current={item === locale ? 'true' : undefined}
                      data-language-link
                      data-mobile-drawer-link
                    >
                      <span dir="auto">{localeNames[item]}</span>
                      {item === locale && <span class="active-mark">✓</span>}
                    </a>
                  ))
                }
              </div>
            </section>
            <a
              class="button button-primary-dark mobile-drawer-cta"
              href={localizedPath(locale, 'contact')}
              data-mobile-drawer-link
            >
              {dictionary.actions.contact}
            </a>
            <a
              class="social-link mobile-drawer-social"
              href={socialProfiles.instagram.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={socialProfiles.instagram.label}
              data-mobile-drawer-link
            >
              <InstagramIcon />
              <span>{dictionary.social.instagram}</span>
            </a>
          </aside>
        </div>
      </div>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="site-header">
      <div class="container footer-inner">
        <a
          class="brand footer-brand"
          href={localizedPath(locale)}
          aria-label="Heavens home"
        >
          <img
            src={brandAssets.logo.src}
            width={brandAssets.logo.width}
            height={brandAssets.logo.height}
            alt="Heavens"
          />
          <span>
            <span class="footer-brand-meta">{site.slogan}</span>
          </span>
        </a>
        <nav class="nav" aria-label="Legal navigation">
          {
            routeSlugs
              .filter((item) =>
                ['legal', 'privacy', 'cookies', 'terms'].includes(item),
              )
              .map((item) => (
                <a href={localizedPath(locale, item)}>
                  {dictionary.pages[item].heading}
                </a>
              ))
          }
        </nav>
        <a
          class="social-link footer-social-link"
          href={socialProfiles.instagram.url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={socialProfiles.instagram.label}
        >
          <InstagramIcon />
          <span>{dictionary.social.instagram}</span>
        </a>
      </div>
    </footer>
    <script is:inline src="/scripts/language-preference.js" defer></script>
  </body>
</html>
