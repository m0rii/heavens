---
import { localizedPath } from '@/config/routes';
import FocusCard from '@/components/FocusCard.astro';
import type { Locale } from '@/i18n/config';
import type { ServicePageCopy } from '@/i18n/ui';

type PageCopy = {
  heading: string;
  intro: string;
};

type Props = {
  locale: Locale;
  page: PageCopy;
  servicePage: ServicePageCopy;
};

const { locale, page, servicePage } = Astro.props;
const focusItems = servicePage.processSteps ?? servicePage.heroItems;
---

<section
  class:list={[
    'service-hero',
    `service-hero-${servicePage.variant}`,
    'section-dark',
  ]}
  data-service-page={servicePage.variant}
>
  <div class="container service-hero-inner">
    <div class="service-hero-copy">
      <p class="eyebrow">{servicePage.eyebrow}</p>
      <h1>{page.heading}</h1>
      <p class="service-hero-lead">{page.intro}</p>
      <a class="service-hero-link" href={localizedPath(locale, 'contact')}>
        {servicePage.cta.label}
      </a>
    </div>

    <FocusCard
      label={servicePage.heroSecondaryLabel}
      items={focusItems}
      stats={servicePage.heroStats}
      ariaLabel={servicePage.heroSecondaryLabel}
      className={`service-hero-panel service-hero-panel-${servicePage.variant}`}
      listClassName="service-hero-tags"
      showMediaGraphic={servicePage.variant === 'media'}
    />
  </div>
</section>

<section class="service-section service-section-primary section-ivory">
  <div class="container">
    <div class="section-heading">
      <p class="eyebrow">{servicePage.services.eyebrow}</p>
      <h2>{servicePage.services.heading}</h2>
      <p>{servicePage.services.intro}</p>
    </div>
    <div class="service-card-grid">
      {
        servicePage.services.cards.map((card) => (
          <article class="service-card">
            <h3>{card.title}</h3>
            <p>{card.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

{
  servicePage.detailSections.map((section, sectionIndex) => (
    <section
      class:list={[
        'service-section',
        sectionIndex % 2 === 0 ? 'section-ivory' : 'service-section-soft',
      ]}
    >
      <div class="container service-detail-layout">
        <div class="section-heading service-detail-heading">
          <p class="eyebrow">{section.eyebrow}</p>
          <h2>{section.heading}</h2>
          <p>{section.body}</p>
          {section.note && <p class="service-note">{section.note}</p>}
        </div>

        {section.items && (
          <div class="service-detail-grid">
            {section.items.map((item) => (
              <article class="service-detail-item">
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </article>
            ))}
          </div>
        )}
      </div>
    </section>
  ))
}

<section class="service-cta section-dark">
  <div class="container service-cta-inner">
    <div>
      <p class="eyebrow">{servicePage.eyebrow}</p>
      <h2>{servicePage.cta.heading}</h2>
      <p>{servicePage.cta.body}</p>
    </div>
    <a
      class="button button-primary-dark"
      href={localizedPath(locale, 'contact')}
    >
      {servicePage.cta.label}
    </a>
  </div>
</section>
